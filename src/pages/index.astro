---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Your self-hosted markdown notes, powered by AI</h1>
			<p>
				A private web app for writing, organizing, and viewing markdown notes with built-in AI support.
				Ask questions about your own notes, get instant summaries, and keep everything on your own server.
			</p>
			<section>
				<h2>Why it matters</h2>
				<p>
				Not all productivity tools should live in the cloud. This app gives you full control over your notes
				while adding smart AI interaction so your knowledge stays useful and accessible.
				</p>
			</section>
			<section>
				<h2>Core features</h2>
				<ul>
					<li>Write and edit notes using markdown syntax.</li>
					<li>Preview rendered notes instantly with clean formatting.</li>
					<li>Interact with AI to ask questions, summarize content, or explore ideas.</li>
					<li>Self-hosted deployment for privacy, security, and ownership.</li>
				</ul>
			</section>
			<section>
				<h2>Get started</h2>
				<p>
				Install the app, point it at your server or home network, and start capturing knowledge in markdown.
				Then use the AI assistant to turn your notes into answers, insights, and next actions.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
