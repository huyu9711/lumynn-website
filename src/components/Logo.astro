---
import { SITE_TITLE } from '../consts';
---

<a href="/" class="logo" aria-label={SITE_TITLE}>
	<svg width="20" height="20" viewBox="0 0 512 512" aria-hidden="true" style="margin-right: 7px; vertical-align: -3px;">
		<defs>
			<linearGradient id="lumynn-m" x1="172" y1="118" x2="388" y2="428" gradientUnits="userSpaceOnUse">
				<stop offset="0" stop-color="#9ba66d"/>
				<stop offset="1" stop-color="#68734a"/>
			</linearGradient>
		</defs>
		<rect width="512" height="512" rx="108" fill="currentColor" opacity="0.1"/>
		<path d="M176 116h86v236h142v78H176z" fill="url(#lumynn-m)"/>
	</svg>
	<span>{SITE_TITLE}</span>
</a>

<style>
	.logo {
		display: inline-flex;
		align-items: center;
		font-weight: 700;
		font-size: 1.05rem;
		color: var(--lumynn-ink);
		text-decoration: none;
		border-bottom: none !important;
		letter-spacing: -0.01em;
	}
</style>